{
  "name": "discordjs-typescript-template",
  "description": "Feature-first Discord.js v14 bot template using Bun, TypeScript, Prisma, Express and Biome.",
  "version": "1.0.0",
  "private": false,
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --watch apps/runtime/src/main.ts",
    "start": "bun apps/runtime/src/main.ts",
    "build": "bun run db:generate && bun build apps/runtime/src/main.ts --target=bun --packages=external --outdir=dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "bun test",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:studio": "bunx --bun prisma studio",
    "db:seed": "bun packages/database/prisma/seed.ts",
    "commands:deploy": "bun apps/runtime/src/scripts/commands.ts deploy:global",
    "commands:deploy:guild": "bun apps/runtime/src/scripts/commands.ts deploy:guild",
    "commands:reset": "bun apps/runtime/src/scripts/commands.ts reset"
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "7.8.0",
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "@types/express": "5.0.6",
    "prisma": "7.8.0",
    "typescript": "6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "prisma",
    "@prisma/client",
    "@prisma/engines"
  ]
}
