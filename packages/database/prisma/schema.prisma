generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  engineType          = "client"
  runtime             = "bun"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "sqlite"
}

model GuildConfig {
  guildId   String   @id
  prefix    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommandLog {
  id           String   @id @default(cuid())
  commandName  String
  guildId      String?
  userId       String
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([commandName])
  @@index([guildId])
  @@index([createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  guildId     String
  featureName String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([guildId, featureName])
  @@index([guildId])
}

model BotSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
